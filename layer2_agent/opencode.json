{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-3-flash-preview",
  "permission": {
    "bash": {
      "*": "allow",
      "rm -rf *": "deny",
      "git push *": "deny"
    },
    "edit": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow"
  },
  "mcp": {
    "chill-tools": {
      "type": "local",
      "command": [
        "/home/test/voice-first-driver/.venv/bin/python",
        "/home/test/voice-first-driver/layer3_tools/server.py"
      ],
      "enabled": true,
      "timeout": 10000
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8000
  }
}
