# Required: Anthropic API key for the agent (OpenCode)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: OpenAI API key (for realtime transcription, future use)
OPENAI_API_KEY=sk-your-key-here

# Optional: Telegram integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: OpenCode binary path (default: opencode)
OPENCODE_BIN=opencode

# Optional: OpenCode serve port (default: 4096)
OPENCODE_PORT=4096

# Optional: Data directory for tools (default: ./data in repo root)
CHILL_DATA_DIR=./data
